# Copy this file to .env.local and set VITE_MCP_URL to connect the webterm
# to a running legal-mcp SSE server instead of mock data.
#
# 1. Start the server:
#      cd legal-mcp
#      pip install -e .
#      python main.py --transport sse
#
# 2. Copy this file:
#      cp .env.local.example .env.local
#
# 3. Restart the dev server:
#      npm run dev

VITE_MCP_URL=http://localhost:8000
